<!DOCTYPE Menu PUBLIC '-//freedesktop//DTD Menu 1.0//EN' 'http://www.freedesktop.org/standards/menu-spec/menu-1.0.dtd'>
<Menu>
 <Layout>
  <Merge type="menus"/>
  <Menuname>Office</Menuname>
  <Menuname>Graphics</Menuname>
  <Menuname>Games</Menuname>
  <Menuname>Internet</Menuname>
  <Menuname>Multimedia</Menuname>
  <Menuname>Utilities</Menuname>
  <Menuname>System</Menuname>
  <Menuname>Applications</Menuname>
 </Layout>
 <Menu>
  <Name>Office</Name>
  <Exclude>
   <Filename>libreoffice-draw.desktop</Filename>
  </Exclude>
  <Layout>
   <Merge type="files"/>
   <Filename>libreoffice-startcenter.desktop</Filename>
   <Filename>libreoffice-calc.desktop</Filename>
   <Filename>libreoffice-impress.desktop</Filename>
   <Filename>libreoffice-math.desktop</Filename>
   <Filename>libreoffice-writer.desktop</Filename>
   <Filename>org.kde.okular.desktop</Filename>
   <Separator/>
   <Merge type="menus"/>
   <Menuname>More</Menuname>
  </Layout>
 </Menu>
 <Menu>
  <Name>Graphics</Name>
  <Exclude>
   <Filename>org.kde.okular.desktop</Filename>
  </Exclude>
  <Layout>
   <Merge type="files"/>
   <Filename>gimp.desktop</Filename>
   <Filename>org.kde.gwenview.desktop</Filename>
   <Filename>display-im7.q16.desktop</Filename>
   <Filename>org.kde.krita.desktop</Filename>
   <Filename>libreoffice-draw.desktop</Filename>
   <Separator/>
   <Merge type="menus"/>
   <Menuname>More</Menuname>
  </Layout>
 </Menu>
 <Menu>
  <Name>Multimedia</Name>
  <Exclude>
   <Filename>qv4l2.desktop</Filename>
   <Filename>qvidcap.desktop</Filename>
  </Exclude>
  <Layout>
   <Merge type="files"/>
   <Filename>audacity.desktop</Filename>
   <Filename>org.kde.dragonplayer.desktop</Filename>
   <Filename>org.kde.juk.desktop</Filename>
   <Filename>org.kde.kdenlive.desktop</Filename>
   <Filename>org.mixxx.Mixxx.desktop</Filename>
   <Separator/>
   <Merge type="menus"/>
   <Menuname>More</Menuname>
  </Layout>
 </Menu>
 <Menu>
  <Name>Utilities</Name>
  <Exclude>
   <Filename>org.kde.kwrite.desktop</Filename>
   <Filename>vim.desktop</Filename>
   <Filename>mcedit.desktop</Filename>
   <Filename>mc.desktop</Filename>
  </Exclude>
  <Layout>
   <Merge type="files"/>
   <Filename>org.kde.ark.desktop</Filename>
   <Filename>org.bleachbit.BleachBit.desktop</Filename>
   <Filename>com.github.tchx84.Flatseal.desktop</Filename>
   <Filename>org.kde.sweeper.desktop</Filename>
   <Filename>org.kde.kcalc.desktop</Filename>
   <Filename>org.kde.kate.desktop</Filename>
   <Filename>org.kde.kfind.desktop</Filename>
   <Filename>org.kde.kmag.desktop</Filename>
   <Filename>org.kde.kmousetool.desktop</Filename>
   <Filename>org.kde.kmouth.desktop</Filename>
   <Merge type="menus"/>
   <Menuname>XUtilities</Menuname>
   <Filename>it.mijorus.gearlever.desktop</Filename>
   <Filename>org.kde.spectacle.desktop</Filename>
   <Filename>org.kde.plasma.emojier.desktop</Filename>
   <Separator/>
   <Menuname>More</Menuname>
  </Layout>
 </Menu>
 <Menu>
  <Name>System</Name>
  <Exclude>
   <Filename>org.bleachbit.BleachBit.desktop</Filename>
   <Filename>org.kde.kinfocenter.desktop</Filename>
   <Filename>avahi-discover.desktop</Filename>
   <Filename>lstopo.desktop</Filename>
   <Filename>mc.desktop</Filename>
   <Filename>debian-uxterm.desktop</Filename>
   <Filename>debian-xterm.desktop</Filename>
   <Filename>org.kde.kwalletmanager.desktop</Filename>
  </Exclude>
  <Layout>
   <Merge type="files"/>
   <Filename>bleachbit-root.desktop</Filename>
   <Filename>org.kde.discover.desktop</Filename>
   <Filename>org.kde.dolphin.desktop</Filename>
   <Filename>ca.desrt.dconf-editor.desktop</Filename>
   <Filename>org.kde.kmenuedit.desktop</Filename>
   <Filename>System Maintenance.desktop</Filename>
   <Filename>org.kde.konsole.desktop</Filename>
   <Filename>virt-manager.desktop</Filename>
   <Filename>org.kde.plasma-systemmonitor.desktop</Filename>
   <Merge type="menus"/>
   <Menuname>Terminal</Menuname>
   <Filename>org.kde.drkonqi.coredump.gui.desktop</Filename>
   <Menuname>ScreenSavers</Menuname>
   <Filename>timeshift-gtk.desktop</Filename>
   <Filename>systemsettings.desktop</Filename>
   <Filename>org.kde.partitionmanager.desktop</Filename>
   <Separator/>
   <Menuname>More</Menuname>
  </Layout>
 </Menu>
